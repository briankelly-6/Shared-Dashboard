# ---------------------------------------------------------------------------
# BK/AO Dashboard — environment variables
# Copy this file to `.env` (or `.env.local`) for local dev, and set the SAME
# three variables in your host (e.g. Vercel) for production.
#
# All three are VITE_-prefixed, so they are embedded in the built site. That is
# expected here: this is a low-confidentiality internal board (see README).
# ---------------------------------------------------------------------------

# Your Supabase project URL, e.g. https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Your Supabase project's public anon key (Project Settings -> API -> anon key)
VITE_SUPABASE_ANON_KEY=

# The shared 6-digit numeric code that unlocks the board, e.g. 482915
VITE_APP_ACCESS_CODE=
