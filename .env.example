# ---------------------------------------------------------------------------
# BK/AO Dashboard — frontend environment
# Copy this file to `.env` (or `.env.local`) and fill in your real values.
# Only VITE_-prefixed vars are exposed to the browser; both of these are
# safe to ship to the client (the anon key is protected by RLS).
# ---------------------------------------------------------------------------

# Your Supabase project URL, e.g. https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Your Supabase project's public anon key (Project Settings → API)
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# The following are NOT used by the frontend. They are set as Supabase
# secrets for the `verify-code` Edge Function (see README). Listed here only
# as a reminder — do NOT put them in this frontend .env file.
#
#   APP_ACCESS_CODE        the shared 6-digit numeric code (e.g. 482915)
#   SHARED_USER_EMAIL      email of the one shared Supabase Auth account
#   SHARED_USER_PASSWORD   password for that shared account
#
# (SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are injected
#  into Edge Functions automatically by Supabase.)
# ---------------------------------------------------------------------------
